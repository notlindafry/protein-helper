# Build-time only. NOT needed to run or deploy the app — the nutrition dataset is baked
# into lib/foods.ts and the client makes no nutrition API calls.
#
# Set this only when running `npm run build:data` to verify/refresh values against the
# live USDA FoodData Central API. Never commit a real key; never expose it to the client.
# Free key: https://fdc.nal.usda.gov/api-key-signup.html
FDC_API_KEY=
